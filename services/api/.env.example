PORT=8787

# Comma-separated allowed browser origins.
# Production example:
# CORS_ORIGINS=https://lerna.app,https://www.lerna.app
CORS_ORIGINS=http://localhost:5173

DATABASE_URL=postgres://postgres:postgres@localhost:54322/postgres

SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=<from Supabase Dashboard or local Supabase>
SUPABASE_JWT_SECRET=<from Supabase Dashboard Project Settings API JWT Secret>

# Sessions repository — 'in-memory' for tests/dev, 'drizzle' for real Postgres
SESSIONS_REPO=in-memory

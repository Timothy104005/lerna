{
  "name": "@lerna/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"@lerna/api lint stub: eslint will be added in W3\"",
    "test": "vitest run",
    "db:introspect": "drizzle-kit introspect --config=drizzle.config.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "hono-rate-limiter": "^0.5.3",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}

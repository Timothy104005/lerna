{
  "appId": "com.timothychen.yptplus",
  "appName": "YPT++",
  "webDir": "www",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "hostname": "localhost"
  },
  "ios": {
    "contentInset": "always",
    "backgroundColor": "#faf9f6",
    "limitsNavigationsToAppBoundDomains": false
  },
  "android": {
    "backgroundColor": "#faf9f6"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#faf9f6",
      "showSpinner": false,
      "androidSpinnerStyle": "small",
      "iosSpinnerStyle": "small"
    }
  }
}

.ypt-graph-add-btn {
  border-radius: 999px;
  padding: 6px 10px;
  font-size: 11px;
  font-weight: 600;
}

.ypt-graph-expression-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.ypt-graph-row {
  border: 1px solid #e5e2dc;
  border-radius: 16px;
  background: #ffffff;
  padding: 10px;

    align-items: flex-start;
  }

  .ypt-calc-shell,
  .ypt-graph-shell {
    border-radius: 20px;
  }

  .ypt-calc-device {
    max-width: none;
  }

  .ypt-calc-keypad {
    gap: 6px;
  }

  .ypt-calc-key {

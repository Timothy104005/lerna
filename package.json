{
  "name": "lerna-mobile-shell",
  "version": "1.0.0",
  "private": true,
  "description": "Android packaging and mobile build tooling for the Lerna study app.",
  "scripts": {
    "build:cloud-sync": "node scripts/build-cloud-sync.js",
    "build:site": "npm run build:cloud-sync && node scripts/build-site.js",
    "pack:site:zip": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pack-site-zip.ps1",
    "build:site:zip": "npm run build:site && npm run pack:site:zip",
    "verify:deploy": "node scripts/verify-deploy.js",
    "build:mobile:web": "npm run build:cloud-sync && node scripts/build-mobile-web.js",
    "android:doctor": "npx cap doctor",
    "android:sync": "npm run build:mobile:web && npx cap sync android",
    "android:copy": "npm run build:mobile:web && npx cap copy android",
    "android:open": "npx cap open android",
    "android:run": "npm run android:sync && npx cap run android",
    "android:assets": "npx capacitor-assets generate --android --assetPath assets --iconBackgroundColor=#ffd4ac --iconBackgroundColorDark=#ffd4ac --splashBackgroundColor=#ffd4ac --splashBackgroundColorDark=#ffd4ac",
    "android:gradle:debug": "powershell -NoProfile -Command \"Set-Location android; ./gradlew.bat assembleDebug\"",
    "android:gradle:aab": "powershell -NoProfile -Command \"Set-Location android; ./gradlew.bat bundleRelease\"",
    "android:build:debug": "npm run android:sync && npm run android:gradle:debug",
    "android:build:aab": "npm run android:sync && npm run android:gradle:aab"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@supabase/supabase-js": "^2.104.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.0",
    "esbuild": "^0.28.0"
  }
}
